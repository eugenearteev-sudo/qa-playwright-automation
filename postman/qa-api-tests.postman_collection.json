      "name": "POST login simulation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains username\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.json.username).to.eql(\"test_user\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains password\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.json.password).to.eql(\"123456\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
